{
  "name": "sitio-institucional",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "urls": "node scripts/print-show-urls.mjs",
    "ngrok": "node scripts/ngrok-run.mjs",
    "build": "payload generate:importmap && next build",
    "start": "next start",
    "lint": "eslint",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "seed": "payload run scripts/seed.ts",
    "git:time-travel": "git-time-travel",
    "git:time-travel:1": "git-time-travel -c 1",
    "git:time-travel:all": "git-time-travel -a",
    "git:time-travel:interactive": "git-time-travel -i",
    "git:time-travel:help": "git-time-travel --help"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.844.0",
    "@payloadcms/db-postgres": "^3.77.0",
    "@payloadcms/db-sqlite": "^3.77.0",
    "@payloadcms/next": "^3.77.0",
    "@payloadcms/richtext-lexical": "^3.77.0",
    "@payloadcms/storage-s3": "^3.77.0",
    "graphql": "^16.9.0",
    "lucide-react": "^1.11.0",
    "next": "^16.2.6",
    "next-intl": "^4.11.0",
    "payload": "^3.77.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.1"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.13.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "git-time-travel": "^2.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "volta": {
    "node": "24.15.0"
  }
}
